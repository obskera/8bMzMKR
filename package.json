{
    "name": "8bmzmkr",
    "productName": "8bMzMKR",
    "version": "0.1.0",
    "description": "8bMzMKR chiptune music editor — Electron + React + TypeScript",
    "author": "obskera",
    "license": "SEE LICENSE IN LICENSE",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "dist": "npm run build && electron-builder",
        "dist:mac": "npm run build && electron-builder --mac",
        "dist:mac:signed:tmp": "npm run build && npx electron-builder --mac -c.directories.output=/tmp/8bm-dist",
        "dist:mac:unsigned": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
        "dist:win": "npm run build && electron-builder --win",
        "preview": "electron-vite preview",
        "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
        "lint": "eslint src --ext .ts,.tsx",
        "build:web": "vite build --config vite.web.config.ts",
        "preview:web": "vite preview --config vite.web.config.ts"
    },
    "dependencies": {
        "@electron-toolkit/preload": "^3.0.2",
        "@electron-toolkit/tsconfig": "^2.0.0",
        "@electron-toolkit/utils": "^4.0.0",
        "ffmpeg-static": "^5.3.0",
        "fluent-ffmpeg": "^2.1.3",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tone": "^15.1.22",
        "zod": "^3.24.1",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/node": "^22.13.0",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^4.3.4",
        "electron": "^34.3.0",
        "electron-builder": "^25.1.8",
        "electron-vite": "^3.0.0",
        "typescript": "^5.7.3",
        "vite": "^6.1.1"
    },
    "build": {
        "appId": "com.obskera.8bmzmkr",
        "productName": "8bMzMKR",
        "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
        "afterPack": "build/afterPack.js",
        "directories": {
            "output": "dist"
        },
        "files": [
            "out/**",
            "package.json"
        ],
        "mac": {
            "icon": "build/icons/icon.icns",
            "category": "public.app-category.music",
            "target": [
                "dmg",
                "zip"
            ]
        },
        "win": {
            "icon": "build/icons/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
